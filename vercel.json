{
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/backup",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/advance-day",
      "schedule": "0 22 * * 1-4"
    },
    {
      "path": "/api/advance-day",
      "schedule": "0 4 * * 6"
    },
    {
      "path": "/api/advance-day",
      "schedule": "0 9 * * 6"
    },
    {
      "path": "/api/release-schedule",
      "schedule": "0 16 * * 0"
    }
  ]
}
